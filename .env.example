PORT=3000
MONGODB_URI=mongodb://localhost:27017/seapedia
JWT_SECRET=your_jwt_secret_here
# Shorter = safer but more frequent re-login. 1d is a reasonable default for e-commerce.
# For higher security set to 15m and implement refresh token flow.
JWT_EXPIRES_IN=1d
NODE_ENV=development
ENABLE_CRON=false
LATE_ORDER_CRON_SCHEDULE=*/5 * * * *
